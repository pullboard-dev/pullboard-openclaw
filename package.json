{
  "name": "@pullboard/openclaw-pullboard",
  "version": "0.4.1",
  "description": "Native OpenClaw agent-tools for Pullboard — claim work atomically, submit with real evidence, and have a different principal verify it on a shared coordination board.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^22.14.0 || ^24.0.0"
  },
  "files": [
    "dist",
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "pullboard",
    "ai-agents",
    "agent-coordination",
    "multi-agent",
    "verification"
  ],
  "homepage": "https://pullboard.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pullboard-dev/pullboard-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/pullboard-dev/pullboard-openclaw/issues"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.15-beta.1",
      "minGatewayVersion": "2026.4.15-beta.1"
    },
    "build": {
      "openclawVersion": "2026.4.15-beta.1",
      "pluginSdkVersion": "2026.4.15-beta.1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.52"
  },
  "scripts": {
    "build": "esbuild index.ts --bundle --outfile=dist/index.js --format=esm --platform=node --packages=external",
    "build:check": "npm run build && git diff --exit-code -- dist/index.js",
    "test": "npm run build:check && node --test test/compiled-artifact.test.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0"
  }
}
